{
  "name": "@invariance/mcp",
  "version": "0.2.0",
  "description": "Invariance MCP server — connect AI coding agents to the Invariance observability platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "invariance-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "invariance",
    "observability",
    "ai",
    "agents",
    "model-context-protocol"
  ],
  "author": "Invariance AI <engineering@invariance.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/invariance-ai/invariance-mcp.git"
  },
  "homepage": "https://github.com/invariance-ai/invariance-mcp",
  "bugs": {
    "url": "https://github.com/invariance-ai/invariance-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@invariance/sdk": "file:../invariance-typescript",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
